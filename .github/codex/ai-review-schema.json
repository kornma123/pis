{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "COREONE AI review result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "findings"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3000
    },
    "findings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "title",
          "body",
          "path",
          "line"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "line": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    }
  }
}
