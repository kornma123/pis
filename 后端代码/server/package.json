{
  "name": "coreone-backend",
  "version": "1.1.0",
  "description": "COREONE 实验室耗材管理系统后端服务",
  "type": "module",
  "engines": {
    "node": "^22.23.1 || ^24.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.23.1 || ^24.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime-contract.mjs",
    "test:contract": "node --test tests/dependency-runtime-contract.test.mjs",
    "preinstall": "node scripts/check-runtime-contract.mjs",
    "dev": "node scripts/check-runtime-contract.mjs && tsx watch src/app.ts",
    "build": "node scripts/check-runtime-contract.mjs && tsc",
    "start": "node scripts/check-runtime-contract.mjs && node --experimental-sqlite scripts/start-production.mjs",
    "seed": "node scripts/check-runtime-contract.mjs && tsx scripts/seed-acceptance-data.ts",
    "reset-passwords": "node scripts/check-runtime-contract.mjs && tsx scripts/reset-passwords.ts",
    "lint": "eslint src/",
    "test": "node scripts/check-runtime-contract.mjs && node --test tests/dependency-runtime-contract.test.mjs && vitest run",
    "test:node": "node scripts/check-runtime-contract.mjs && node --test tests/dependency-runtime-contract.test.mjs && node --experimental-sqlite node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^1.6.1"
  }
}
